# Railway environment variables for payment engine deployment
# Copy this file to a safe location and fill in the values before deploying

# Application
NODE_ENV=production
PORT=3000
APP_SECRET=your-secret-api-key-here-min-32-chars
APP_ENABLE_DOCS=false
APP_ENABLE_QUEUE_DASHBOARD=false

# Database (Railway Postgres)
# Railway provides DATABASE_URL automatically; app parses it.
# Do not set DB_HOST/DB_PORT/DB_USERNAME/DB_PASSWORD/DB_NAME on Railway.
# DATABASE_URL is injected by Railway when you attach a Postgres service.
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true

# Redis (Railway Redis)
# Railway provides REDIS_URL automatically; app parses it.
# Do not set REDIS_HOST/REDIS_PORT/REDIS_PASSWORD on Railway.
# REDIS_URL is injected by Railway when you attach a Redis service.

# Payment Providers
LENCO_BASE_URL=https://api.lenco.co/access/v1
LENCO_SECRET_KEY=your-lenco-api-key-here
STRIPE_SECRET_KEY=sk_live_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Webhooks
WEBHOOK_SIGNING_SECRET=your-unique-webhook-secret-key-change-in-prod

# CORS (comma-separated)
CORS_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# HTTP
TRUST_PROXY=true
