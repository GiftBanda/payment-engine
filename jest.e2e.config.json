{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testRegex": "test/e2e/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": ["src/**/*.ts", "!src/main.ts", "!**/*.module.ts"],
  "coverageDirectory": "coverage/e2e",
  "testEnvironment": "node"
}
